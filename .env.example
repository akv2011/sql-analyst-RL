API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
HF_TOKEN=your-token-here

# Optional local fallback if you are calling OpenAI directly instead of a
# Hugging Face/OpenAI-compatible endpoint that uses HF_TOKEN.
OPENAI_API_KEY=

# Optional inference.py override. Leave blank to run all tasks.
TASK_IDS=1,2,3

# Optional hosted validation target for scripts/pre_validate.sh.
SPACE_URL=https://your-space.hf.space
